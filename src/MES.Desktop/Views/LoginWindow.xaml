<Window x:Class="MES.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MES 登录" Height="380" Width="360"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize"
        Background="#1565C0">
    <Border Background="White" CornerRadius="8" Margin="28" Padding="24">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="MES 生产执行系统" FontSize="20" FontWeight="Bold"
                       Foreground="#1565C0" HorizontalAlignment="Center"/>
            <TextBlock Text="Manufacturing Execution System" FontSize="11"
                       Foreground="#999" HorizontalAlignment="Center" Margin="0,4,0,24"/>

            <TextBlock Text="用户名" FontSize="12" Foreground="#666"/>
            <TextBox Text="{Binding Username}" FontSize="14" Padding="8,6" Margin="0,4,0,12"
                     BorderThickness="1">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="BorderBrush" Value="#ccc"/>
                        <Style.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#1565C0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <TextBlock Text="密码" FontSize="12" Foreground="#666"/>
            <PasswordBox x:Name="PwdBox" FontSize="14" Padding="8,6" Margin="0,4,0,4"
                         BorderBrush="#ccc" BorderThickness="1"/>

            <TextBlock Text="{Binding Error}" Foreground="#E53935" FontSize="12"
                       Margin="0,8,0,4" Visibility="{Binding Error, Converter={x:Null}}"/>

            <Button Content="登  录" Command="{Binding LoginCmd}"
                    FontSize="15" FontWeight="Bold" Padding="0,10"
                    Background="#1565C0" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Margin="0,12,0,0" IsDefault="True">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Border>
</Window>
