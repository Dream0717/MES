<Window x:Class="MES.Desktop.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MES 系统登录" Height="420" Width="380"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize"
        Background="#1976D2">
    <Grid>
        <Border Background="White" CornerRadius="8" Margin="30" Padding="24">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="MES 生产执行系统" FontSize="22" FontWeight="Bold"
                           Foreground="#1976D2" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Manufacturing Execution System" FontSize="11"
                           Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <TextBlock Text="用户名" FontSize="13" Foreground="#555" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Username, Mode=TwoWay}" 
                         FontSize="14" Padding="8,6" Margin="0,0,0,12"
                         BorderBrush="#DDD" BorderThickness="1"/>

                <TextBlock Text="密码" FontSize="13" Foreground="#555" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" 
                             FontSize="14" Padding="8,6" Margin="0,0,0,16"
                             BorderBrush="#DDD" BorderThickness="1"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF5722"
                           FontSize="12" Margin="0,0,0,8" Visibility="{Binding ErrorMessage, Converter={x:Null}}"/>

                <Button Content="登 录" Command="{Binding LoginCommand}"
                        FontSize="15" FontWeight="Bold"
                        Padding="0,10" Background="#1976D2" Foreground="White"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
