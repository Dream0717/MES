<Window x:Class="MES.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MES 生产执行系统" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 侧边栏 -->
        <Border Grid.Column="0" Background="#1B1B2F">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="16,20">
                    <TextBlock Text="MES" FontSize="22" FontWeight="Bold" Foreground="#1565C0"/>
                    <TextBlock Text="生产执行系统" FontSize="11" Foreground="#888"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="8,0">
                    <TextBlock Text="导航" FontSize="10" Foreground="#555" Margin="12,4"/>
                    <Button Content="📊 生产看板" Command="{Binding NavDashboardCmd}" Style="{StaticResource SideBtn}"/>
                    <Button Content="📋 工单管理" Command="{Binding NavOrdersCmd}" Style="{StaticResource SideBtn}"/>
                    <Button Content="🔧 产品管理" Command="{Binding NavProductsCmd}" Style="{StaticResource SideBtn}"/>
                    <Button Content="🏭 工位管理" Command="{Binding NavWorkstationsCmd}" Style="{StaticResource SideBtn}"/>
                    <Button Content="📝 报工查询" Command="{Binding NavReportsCmd}" Style="{StaticResource SideBtn}"/>
                    <Button Content="👥 用户管理" Command="{Binding NavUsersCmd}" Style="{StaticResource SideBtn}"/>

                    <TextBlock Text="Web 查询" FontSize="10" Foreground="#555" Margin="12,12,12,4"/>
                    <Button Content="🌐 打开浏览器查询" Command="{Binding OpenBrowserCmd}" Style="{StaticResource SideBtn}"/>
                </StackPanel>

                <Border Grid.Row="2" Background="#15152A" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="{Binding UserName}" FontSize="13" Foreground="#CCC"/>
                        <TextBlock Text="{Binding Status}" FontSize="11" Foreground="#888"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶栏 -->
            <Border Grid.Row="0" Background="White" Padding="16,10" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
                <Grid>
                    <TextBlock Text="{Binding Status}" FontSize="13" Foreground="#666" VerticalAlignment="Center"/>
                    <Button Content="🌐 浏览器查询" Command="{Binding OpenBrowserCmd}"
                            HorizontalAlignment="Right" Padding="10,4"
                            Background="#1565C0" Foreground="White" BorderThickness="0"
                            Cursor="Hand" FontSize="12"/>
                </Grid>
            </Border>

            <!-- 欢迎页 -->
            <Border Grid.Row="1" Background="White" Margin="24" CornerRadius="8" Padding="32">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="👋 欢迎使用 MES 生产执行系统" FontSize="22" FontWeight="Bold"
                               Foreground="#333" HorizontalAlignment="Center"/>
                    <TextBlock Text="使用左侧菜单导航，点击「浏览器查询」可打开 Web 端进行数据查询" 
                               FontSize="13" Foreground="#888" Margin="0,12,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
