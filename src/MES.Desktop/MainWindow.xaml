<Window x:Class="MES.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="MES 生产执行系统" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 侧边栏 -->
        <Border Grid.Column="0" Background="#1E1E2D">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="16,20,16,20">
                    <TextBlock Text="MES" FontSize="24" FontWeight="Bold" Foreground="#1976D2"/>
                    <TextBlock Text="生产执行系统" FontSize="12" Foreground="#888" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- 导航菜单 -->
                <StackPanel Grid.Row="1" Margin="8,0">
                    <TextBlock Text="导航菜单" FontSize="11" Foreground="#555" Margin="12,8,12,8"/>

                    <Button Content="📊  生产看板" Command="{Binding NavigateToDashboardCommand}"
                            Style="{StaticResource SidebarButton}"/>
                    <Button Content="📋  工单管理" Command="{Binding NavigateToWorkOrdersCommand}"
                            Style="{StaticResource SidebarButton}"/>
                    <Button Content="🔧  产品管理" Command="{Binding NavigateToProductsCommand}"
                            Style="{StaticResource SidebarButton}"/>

                    <TextBlock Text="系统" FontSize="11" Foreground="#555" Margin="12,16,12,8"/>
                    <Button Content="👥  用户管理" Style="{StaticResource SidebarButton}"/>
                    <Button Content="⚙️  系统设置" Style="{StaticResource SidebarButton}"/>
                </StackPanel>

                <!-- 底部用户信息 -->
                <Border Grid.Row="2" Background="#151521" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="{Binding UserName}" FontSize="13" Foreground="#CCC"/>
                        <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#888"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 主内容区 - WebView2 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 工具栏 -->
            <Border Grid.Row="0" Background="White" Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
                <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#888"/>
            </Border>

            <!-- WebView2 页面 -->
            <wpf:WebView2 Grid.Row="1" x:Name="Browser"
                          Source="{Binding WebViewUrl}"
                          Margin="0"/>
        </Grid>

        <!-- 加载遮罩 -->
        <Border x:Name="LoadingOverlay" Grid.ColumnSpan="2"
                Background="#80000000" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="正在连接服务器..." FontSize="18" Foreground="White"/>
                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
